{
  "surface": "claude_cowork",
  "family": "claude",
  "display_name": "Claude Cowork",
  "version": "2026-03-30",
  "support_level": "experimental",
  "sources": [
    {
      "label": "Anthropic Knowledge Work Plugins",
      "url": "https://github.com/anthropics/knowledge-work-plugins"
    }
  ],
  "known_locations": [
    {
      "path": "~/.claude",
      "scope_type": "global_user",
      "artifact_type": "directory",
      "reason": "Global Claude/Cowork settings root.",
      "states": ["declared"]
    }
  ],
  "artifact_rules": [
    {
      "glob": "CLAUDE.md",
      "artifact_type": "instructions",
      "reason": "Repo instructions reused by Claude Cowork.",
      "states": ["declared"]
    },
    {
      "glob": ".claude/**/*.json",
      "artifact_type": "config",
      "reason": "Claude Cowork project config.",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".claude/**/*.md",
      "artifact_type": "local_doc",
      "reason": "Claude Cowork docs or plugin docs.",
      "states": ["declared"]
    }
  ],
  "project_discovery_rules": [
    {
      "glob": "CLAUDE.md",
      "kind": "workspace_candidate",
      "score": 215,
      "reason": "Workspace contains CLAUDE.md.",
      "root_strategy": { "type": "match_parent" }
    },
    {
      "glob": ".claude/config.json",
      "kind": "workspace_candidate",
      "score": 205,
      "reason": "Workspace contains .claude/config.json.",
      "root_strategy": { "type": "levels_up", "count": 2 },
      "skip_if_scan_root": true
    },
    {
      "glob": ".claude/**/.claude-plugin/plugin.json",
      "kind": "plugin_package",
      "score": 130,
      "reason": "Plugin package contains .claude-plugin.",
      "root_strategy": { "type": "levels_up", "count": 1 }
    }
  ],
  "observed_probes": ["ps:claude", "ps:cowork"],
  "plugin_system": {
    "system": "claude",
    "install_roots": ["~/.claude/plugins", "~/.config/claude/plugins"],
    "manifest_paths": [".claude-plugin/plugin.json", "plugin.json", "package.json"],
    "config_paths": ["~/.claude/config.json", "{project}/.claude/config.json"],
    "compatibility": ["claude_code", "claude_cowork"]
  }
}

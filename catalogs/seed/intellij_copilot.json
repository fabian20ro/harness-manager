{
  "surface": "intellij_copilot",
  "family": "copilot",
  "display_name": "IntelliJ/Copilot",
  "version": "2026-04-06",
  "support_level": "full",
  "sources": [
    {
      "label": "GitHub Copilot for IntelliJ",
      "url": "https://docs.github.com/en/copilot/using-github-copilot/getting-started-with-github-copilot-in-jetbrains-ide"
    }
  ],
  "known_locations": [],
  "artifact_rules": [
    {
      "glob": ".github/copilot-instructions.md",
      "artifact_type": "instructions",
      "reason": "Repo Copilot instructions.",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".github/git-commit-instructions.md",
      "artifact_type": "instructions",
      "reason": "Commit message instructions.",
      "states": ["declared"]
    },
    {
      "glob": "AGENTS.md",
      "artifact_type": "instructions",
      "reason": "Standardized agent rules.",
      "states": ["declared", "effective"]
    }
  ],
  "project_discovery_rules": [
    {
      "glob": ".github/copilot-instructions.md",
      "kind": "workspace_candidate",
      "score": 200,
      "reason": "Workspace contains .github/copilot-instructions.md.",
      "root_strategy": { "type": "levels_up", "count": 2 },
      "skip_if_scan_root": true
    }
  ],
  "observed_probes": ["ps:idea", "ps:copilot"],
  "plugin_system": null
}

{
  "surface": "copilot_cli",
  "family": "copilot",
  "display_name": "Copilot CLI",
  "version": "2026-04-06",
  "support_level": "full",
  "sources": [
    {
      "label": "GitHub Copilot CLI v2 Docs",
      "url": "https://docs.github.com/en/copilot/github-copilot-cli"
    }
  ],
  "known_locations": [
    {
      "path": "~/.copilot",
      "scope_type": "global_user",
      "artifact_type": "directory",
      "reason": "Global Copilot settings and instructions root.",
      "states": ["declared"]
    }
  ],
  "artifact_rules": [
    {
      "glob": ".github/copilot-instructions.md",
      "artifact_type": "instructions",
      "reason": "Repo Copilot instructions.",
      "states": ["declared", "effective"]
    },
    {
      "glob": "AGENTS.md",
      "artifact_type": "instructions",
      "reason": "Standardized agent rules.",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".github/hooks.json",
      "artifact_type": "config",
      "reason": "Copilot CLI hooks (v2).",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".github/instructions/**/*.instructions.md",
      "artifact_type": "instructions",
      "reason": "Path-specific instructions.",
      "states": ["declared"]
    },
    {
      "glob": "~/.copilot/config.json",
      "artifact_type": "config",
      "reason": "Global Copilot CLI v2 configuration.",
      "states": ["declared", "effective"]
    },
    {
      "glob": "~/.copilot/instructions.md",
      "artifact_type": "instructions",
      "reason": "Global user instructions.",
      "states": ["declared", "effective"]
    }
  ],
  "validation_rules": [
    {
      "type": "env_var_presence",
      "target": "GITHUB_TOKEN",
      "severity": "critical",
      "description": "GitHub Token required for Copilot CLI auth."
    },
    {
      "type": "file_schema",
      "target": "copilot-instructions.md",
      "severity": "warning",
      "description": "Copilot instructions should follow the standard mandate schema."
    }
  ],
  "project_discovery_rules": [
    {
      "glob": ".github/copilot-instructions.md",
      "kind": "workspace_candidate",
      "score": 210,
      "reason": "Workspace contains .github/copilot-instructions.md.",
      "root_strategy": { "type": "levels_up", "count": 2 },
      "skip_if_scan_root": true
    },
    {
      "glob": ".github/hooks.json",
      "kind": "workspace_candidate",
      "score": 190,
      "reason": "Workspace contains Copilot CLI hooks.",
      "root_strategy": { "type": "levels_up", "count": 2 },
      "skip_if_scan_root": true
    },
    {
      "glob": ".github/skills/*/SKILL.md",
      "kind": "plugin_package",
      "score": 140,
      "reason": "Plugin package contains .github/skills/*/SKILL.md.",
      "root_strategy": { "type": "match_parent" }
    }
  ],
  "observed_probes": ["ps:copilot", "ps:gh"],
  "plugin_system": null
}

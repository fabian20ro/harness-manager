{
  "surface": "claude_code",
  "family": "claude",
  "display_name": "Claude Code",
  "version": "2026-04-06",
  "support_level": "full",
  "sources": [
    {
      "label": "Anthropic Claude Code Docs",
      "url": "https://docs.anthropic.com/claude/docs/claude-code"
    }
  ],
  "known_locations": [
    {
      "path": "~/.claude",
      "scope_type": "global_user",
      "artifact_type": "directory",
      "reason": "Global Claude settings and instructions root.",
      "states": ["declared"]
    }
  ],
  "artifact_rules": [
    {
      "glob": "CLAUDE.md",
      "artifact_type": "instructions",
      "reason": "Repo instructions for Claude.",
      "states": ["declared", "effective"]
    },
    {
      "glob": "AGENTS.md",
      "artifact_type": "instructions",
      "reason": "Standardized agent rules.",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".claude/settings.json",
      "artifact_type": "config",
      "reason": "Shared project settings.",
      "states": ["declared", "effective"]
    },
    {
      "glob": ".claude/settings.local.json",
      "artifact_type": "config",
      "reason": "Local project overrides.",
      "states": ["declared"]
    },
    {
      "glob": ".claude/rules/**/*.md",
      "artifact_type": "instructions",
      "reason": "Modular project rules.",
      "states": ["declared"]
    },
    {
      "glob": "~/.claude/CLAUDE.md",
      "artifact_type": "instructions",
      "reason": "Global user instructions.",
      "states": ["declared", "effective"]
    }
  ],
  "validation_rules": [
    {
      "type": "env_var_presence",
      "target": "ANTHROPIC_API_KEY",
      "severity": "critical",
      "description": "Anthropic API Key required for Claude Code."
    },
    {
      "type": "file_schema",
      "target": "CLAUDE.md",
      "severity": "warning",
      "description": "CLAUDE.md should contain project context and guidelines."
    }
  ],
  "project_discovery_rules": [
    {
      "glob": "CLAUDE.md",
      "kind": "workspace_candidate",
      "score": 215,
      "reason": "Workspace contains CLAUDE.md.",
      "root_strategy": { "type": "match_parent" }
    },
    {
      "glob": ".claude/settings.json",
      "kind": "workspace_candidate",
      "score": 205,
      "reason": "Workspace contains .claude/settings.json.",
      "root_strategy": { "type": "levels_up", "count": 1 }
    }
  ],
  "observed_probes": ["ps:claude"],
  "plugin_system": {
    "system": "claude",
    "install_roots": ["~/.claude/plugins"],
    "manifest_paths": [".claude-plugin/plugin.json", "plugin.json"],
    "config_paths": ["~/.claude/settings.json", "{project}/.claude/settings.json"],
    "compatibility": ["claude_code", "claude_cowork"]
  }
}
